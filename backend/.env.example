DATABASE_URL=postgres://vocab_user:vocab_pass@localhost:5432/vocab_db
PORT=3000
# Comma-separated list of allowed CORS origins (production). Leave empty to allow all (dev).
FRONTEND_URL=
# Admin password. Required for create/update/delete (word write operations).
# Reads stay public. Changing this invalidates existing admin sessions.
ADMIN_PASSWORD=change-me
